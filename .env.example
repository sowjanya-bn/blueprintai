# Example environment variables for local development
# If you don't have Google Gemini credentials, you can leave GEMINI_API_KEY blank and
# use local mocks or the existing retriever/generator stubs.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Optional OpenAI key if you swap LLM backends
OPENAI_API_KEY=
# Copy this file to .env and replace the API key value with your real key.
# Do NOT commit your .env to version control.

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-3-flash-preview

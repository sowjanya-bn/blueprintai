    {"id": "color.brand-secondary",  "category": "color",      "value": "#1e293b", "status": "stable"},
    {"id": "color.surface",          "category": "color",      "value": "#f8fafc", "status": "stable"},
    {"id": "color.error",            "category": "color",      "value": "#dc2626", "status": "stable"},
    {"id": "color.success",          "category": "color",      "value": "#16a34a", "status": "stable"},
    {"id": "color.accent",           "category": "color",      "value": "#7ef2b3", "status": "stable"},
    {"id": "color.neutral-100",      "category": "color",      "value": "#f1f5f9", "status": "stable"},
    {"id": "color.neutral-900",      "category": "color",      "value": "#0f172a", "status": "stable"},
    {"id": "color.old-primary",      "category": "color",      "value": "#1a56db", "status": "deprecated", "replaced_by": "color.brand-primary"},
    {"id": "color.old-secondary",    "category": "color",      "value": "#6875f5", "status": "deprecated", "replaced_by": "color.brand-secondary"},
    {"id": "font.base",              "category": "typography", "value": "Inter",   "status": "stable"},
    {"id": "font.heading",           "category": "typography", "value": "Inter",   "status": "stable"},
    {"id": "font.mono",              "category": "typography", "value": "JetBrains Mono", "status": "stable"},
    {"id": "font.legacy-body",       "category": "typography", "value": "Open Sans", "status": "deprecated", "replaced_by": "font.base"},
    {"id": "font.legacy-heading",    "category": "typography", "value": "Montserrat", "status": "deprecated", "replaced_by": "font.heading"},
